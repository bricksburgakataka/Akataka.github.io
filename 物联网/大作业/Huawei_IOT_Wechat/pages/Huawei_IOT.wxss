/* pages/Huawei_IOT.wxss */
page {
  background: #0a0e17;
  height: 100vh;
  color: #ffffff;
}

.container {
  padding: 0;
  height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

/* 科技感背景 */
.tech-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
  background: 
      radial-gradient(circle at 20% 80%, rgba(0, 245, 255, 0.1) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba(147, 51, 234, 0.1) 0%, transparent 50%),
      radial-gradient(circle at 40% 40%, rgba(255, 0, 128, 0.05) 0%, transparent 50%);
  background-color: #0a0e17;
}

.grid-lines {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image: 
      linear-gradient(rgba(0, 245, 255, 0.1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 245, 255, 0.1) 1px, transparent 1px);
  background-size: 50px 50px;
  opacity: 0.3;
}

.floating-particles {
  position: absolute;
  width: 100%;
  height: 100%;
}

.particle {
  position: absolute;
  border-radius: 50%;
  background: rgba(0, 245, 255, 0.6);
  filter: blur(1px);
  animation: float 6s infinite ease-in-out;
}

.p1 { width: 6rpx; height: 6rpx; top: 20%; left: 10%; animation-delay: 0s; }
.p2 { width: 4rpx; height: 4rpx; top: 60%; left: 80%; animation-delay: 1s; background: rgba(147, 51, 234, 0.6); }
.p3 { width: 8rpx; height: 8rpx; top: 40%; left: 40%; animation-delay: 2s; }
.p4 { width: 5rpx; height: 5rpx; top: 80%; left: 30%; animation-delay: 3s; background: rgba(255, 0, 128, 0.6); }
.p5 { width: 7rpx; height: 7rpx; top: 10%; left: 70%; animation-delay: 4s; }

@keyframes float {
  0%, 100% { transform: translateY(0) translateX(0); }
  25% { transform: translateY(-20rpx) translateX(10rpx); }
  50% { transform: translateY(10rpx) translateX(-10rpx); }
  75% { transform: translateY(-10rpx) translateX(-15rpx); }
}

/* 头部样式优化 */
.header {
  background: rgba(16, 23, 41, 0.8);
  backdrop-filter: blur(20px);
  padding: 30rpx 40rpx;
  border-bottom: 1rpx solid rgba(0, 245, 255, 0.3);
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
}

.header-glow {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #00f5ff, transparent);
  filter: blur(1px);
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-title {
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 38rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #00f5ff, #9333ea);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #94a3b8;
}

.header-status {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.status-indicator {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  border-radius: 25rpx;
  font-size: 24rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
  background: rgba(16, 23, 41, 0.8);
  border: 1rpx solid;
  backdrop-filter: blur(10px);
}

.status-indicator.online {
  border-color: rgba(0, 245, 255, 0.5);
  color: #00f5ff;
  box-shadow: 0 0 20rpx rgba(0, 245, 255, 0.3);
}

.status-indicator.offline {
  border-color: rgba(248, 113, 113, 0.5);
  color: #f87171;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  animation: pulse 2s infinite;
}

.status-indicator.online .status-dot {
  background: #00f5ff;
  box-shadow: 0 0 10rpx #00f5ff;
}

.status-indicator.offline .status-dot {
  background: #f87171;
  box-shadow: 0 0 10rpx #f87171;
}

.time {
  font-size: 24rpx;
  color: #94a3b8;
  font-family: 'Courier New', monospace;
}

/* 选项卡导航 */
.tab-nav {
  display: flex;
  background: rgba(16, 23, 41, 0.8);
  backdrop-filter: blur(20px);
  padding: 20rpx 40rpx;
  border-bottom: 1rpx solid rgba(0, 245, 255, 0.2);
  flex-shrink: 0;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border-radius: 16rpx;
  transition: all 0.3s ease;
  background: transparent;
  border: none;
}

.tab-item.active {
  background: rgba(0, 245, 255, 0.1);
  border: 1rpx solid rgba(0, 245, 255, 0.3);
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
  transition: all 0.3s ease;
  filter: drop-shadow(0 0 5rpx currentColor);
}

.tab-item.active .tab-icon {
  color: #00f5ff;
  transform: scale(1.1);
}

.tab-text {
  font-size: 24rpx;
  color: #94a3b8;
  transition: all 0.3s ease;
}

.tab-item.active .tab-text {
  color: #00f5ff;
  font-weight: 500;
}

/* 主要内容区域 */
.main-content {
  flex: 1;
  padding: 0 20rpx 20rpx;
  height: auto;
  min-height: 0;
}

scroll-view.main-content {
  height: 100%;
}

scroll-view {
  height: 100%;
  box-sizing: border-box;
}

.tab-content {
  display: none;
}

.tab-content.active {
  display: block;
}

/* 卡片通用样式 */
.card {
  background: rgba(16, 23, 41, 0.6);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
}

.card:active {
  transform: translateY(-2rpx);
  border-color: rgba(0, 245, 255, 0.3);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  text-shadow: 0 0 10rpx rgba(0, 245, 255, 0.5);
}

.card-status {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #94a3b8;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.status-dot.ready {
  background: #22c55e;
  box-shadow: 0 0 10rpx #22c55e;
  animation: pulse 2s infinite;
}

.status-dot.loading {
  background: #f59e0b;
  box-shadow: 0 0 10rpx #f59e0b;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* 拍照控制优化 */
.photo-actions {
  display: flex;
  gap: 20rpx;
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 32rpx;
  border-radius: 16rpx;
  border: none;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s ease;
  backdrop-filter: blur(10px);
}

.btn:active {
  transform: scale(0.98);
}

.btn-primary {
  background: linear-gradient(135deg, #00f5ff, #9333ea);
  color: white;
  box-shadow: 0 8rpx 32rpx rgba(0, 245, 255, 0.3);
  border: 1rpx solid rgba(0, 245, 255, 0.3);
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.1);
  color: #00f5ff;
  border: 1rpx solid rgba(0, 245, 255, 0.3);
}

.btn-large {
  flex: 2;
}

.btn-small {
  padding: 16rpx 24rpx;
  font-size: 24rpx;
}

.btn-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

/* 设备状态提示 */
.device-status-hint {
  margin-top: 20rpx;
  padding: 16rpx;
  background: rgba(245, 158, 11, 0.1);
  border: 1rpx solid rgba(245, 158, 11, 0.3);
  border-radius: 8rpx;
  text-align: center;
}

.hint-text {
  font-size: 24rpx;
  color: #f59e0b;
}

/* AI识别结果优化 */
.ai-badge {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: bold;
}

.ai-badge.has-result {
  background: rgba(34, 197, 94, 0.2);
  color: #22c55e;
  border: 1rpx solid rgba(34, 197, 94, 0.3);
}

.ai-badge.no-result {
  background: rgba(245, 158, 11, 0.2);
  color: #f59e0b;
  border: 1rpx solid rgba(245, 158, 11, 0.3);
}

.ai-content {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.ai-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #e2e8f0;
}

.ai-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.ai-time {
  font-size: 22rpx;
  color: #94a3b8;
}

/* 照片预览样式 */
.photo-preview {
  background: linear-gradient(135deg, rgba(0, 245, 255, 0.1), rgba(147, 51, 234, 0.1));
  border-color: rgba(0, 245, 255, 0.5);
}

.photo-badge {
  padding: 8rpx 16rpx;
  background: rgba(0, 245, 255, 0.2);
  border: 1rpx solid rgba(0, 245, 255, 0.3);
  border-radius: 12rpx;
}

.photo-count {
  font-size: 22rpx;
  color: #00f5ff;
  font-weight: 500;
}

.photo-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.photo-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  width: 100%;
  border: 2rpx dashed rgba(255, 255, 255, 0.2);
}

.placeholder-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.placeholder-text {
  font-size: 28rpx;
  color: #94a3b8;
}

.latest-photo {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  margin-bottom: 24rpx;
}

.photo-actions {
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.photo-actions .btn {
  flex: 1;
}

/* 天气信息卡片样式 */
.weather-info {
  background: linear-gradient(135deg, rgba(0, 245, 255, 0.1), rgba(147, 51, 234, 0.1));
  border-color: rgba(0, 245, 255, 0.5);
}

.weather-badge {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: bold;
}

.weather-badge.has-data {
  background: rgba(34, 197, 94, 0.2);
  color: #22c55e;
  border: 1rpx solid rgba(34, 197, 94, 0.3);
}

.weather-badge.no-data {
  background: rgba(245, 158, 11, 0.2);
  color: #f59e0b;
  border: 1rpx solid rgba(245, 158, 11, 0.3);
}

.weather-content {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.weather-main-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.weather-temp-large {
  font-size: 52rpx;
  font-weight: bold;
  color: #00f5ff;
  text-shadow: 0 0 15rpx rgba(0, 245, 255, 0.5);
}

.weather-condition-main {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.weather-condition-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.weather-city {
  font-size: 24rpx;
  color: #94a3b8;
}

.weather-details-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.weather-detail-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.detail-label {
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 12rpx;
}

.detail-value-large {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
}

/* 日程信息卡片样式 */
.schedule-info {
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.1), rgba(234, 88, 12, 0.1));
  border-color: rgba(245, 158, 11, 0.5);
}

.schedule-badge {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: bold;
}

.schedule-badge.has-reminder {
  background: rgba(245, 158, 11, 0.2);
  color: #f59e0b;
  border: 1rpx solid rgba(245, 158, 11, 0.3);
  animation: glow 2s infinite alternate;
}

.schedule-badge.no-reminder {
  background: rgba(148, 163, 184, 0.2);
  color: #94a3b8;
  border: 1rpx solid rgba(148, 163, 184, 0.3);
}

@keyframes glow {
  from { box-shadow: 0 0 10rpx rgba(245, 158, 11, 0.3); }
  to { box-shadow: 0 0 20rpx rgba(245, 158, 11, 0.6); }
}

.schedule-content {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.schedule-main-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.schedule-time-large {
  font-size: 48rpx;
  font-weight: bold;
  color: #f59e0b;
  text-shadow: 0 0 15rpx rgba(245, 158, 11, 0.5);
}

.schedule-detail-main {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.schedule-next-text {
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 8rpx;
}

.schedule-next-time {
  font-size: 28rpx;
  font-weight: 500;
  color: #ffffff;
}

.schedule-details-content {
  margin-bottom: 24rpx;
}

.schedule-desc-large {
  font-size: 28rpx;
  line-height: 1.6;
  color: #e2e8f0;
  text-align: center;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

/* 底部操作栏优化 */
.bottom-actions {
  background: rgba(16, 23, 41, 0.9);
  backdrop-filter: blur(20px);
  padding: 20rpx 40rpx;
  display: flex;
  justify-content: space-around;
  border-top: 1rpx solid rgba(0, 245, 255, 0.2);
  position: relative;
  flex-shrink: 0;
}

.bottom-glow {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #00f5ff, transparent);
  filter: blur(1px);
}

.btn-bottom {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: none;
  border: none;
  padding: 20rpx;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.btn-bottom.active {
  background: rgba(0, 245, 255, 0.1);
  border: 1rpx solid rgba(0, 245, 255, 0.3);
}

.btn-bottom-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
  transition: all 0.3s ease;
  filter: drop-shadow(0 0 5rpx currentColor);
}

.btn-bottom.active .btn-bottom-icon {
  color: #00f5ff;
  transform: scale(1.1);
}

.btn-bottom-text {
  font-size: 22rpx;
  color: #94a3b8;
  transition: all 0.3s ease;
}

.btn-bottom.active .btn-bottom-text {
  color: #00f5ff;
  font-weight: 500;
}

.btn-bottom:active {
  opacity: 0.7;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .weather-details-grid {
    grid-template-columns: 1fr;
  }
  
  .weather-main-info {
    flex-direction: column;
    text-align: center;
  }
  
  .weather-condition-main {
    align-items: center;
    margin-top: 16rpx;
  }
  
  .schedule-main-info {
    flex-direction: column;
    text-align: center;
  }
  
  .schedule-detail-main {
    align-items: center;
    margin-top: 16rpx;
  }
  
  .photo-actions {
    flex-direction: column;
  }
  
  .btn-large {
    flex: 1;
  }
}